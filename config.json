{
  "config": {
    "RESOURCE_GROUP": "my-resource-group",
    "LOCATION": "eastus",
    "APP_NAME": "my-web-app1",
    "DEPLOY_TARGET": "azure-app-service",
    "ENVIRONMENT": "staging",
    "BRANCH": "main",
    "ENABLE_SAST": true,
    "ENABLE_DAST": false,
    "APP_SERVICE_SKU": "B1"
  },
  "techstack": {
    "language": "python",
    "framework": "fastapi",
    "buildtool": "pip",
    "hasDockerfile": true,
    "hasHelm": false,
    "hasTerraform": true
  },
  "startup_command": "uvicorn main:app --host 0.0.0.0 --port 8000",
  "startup_command_filepath": "startup.sh"
}
